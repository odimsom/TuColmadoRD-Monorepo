{
    "name": "web-admin",
    "version": "0.0.1-test.3",
    "main": "main.js",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "test:selenium:account": "node ./tests/e2e/account-creation.selenium.mjs",
        "test:selenium:task4": "node ./tests/e2e/task4-auth-suite.selenium.mjs",
        "test:e2e:account": "node ./tests/e2e/run-account-e2e.mjs",
        "test:e2e:task4": "node ./tests/e2e/run-task4-e2e.mjs",
        "test:e2e:task4:headed": "set E2E_HEADLESS=false&& node ./tests/e2e/run-task4-e2e.mjs",
        "test:e2e:task4:headed:slow": "set E2E_HEADLESS=false&& set E2E_STEP_DELAY_MS=1200&& node ./tests/e2e/run-task4-e2e.mjs",
        "build:exe": "npm run build && npm run obfuscate && Remove-Item -Recurse -Force dist/web-admin/browser && Rename-Item secured browser -Path dist/web-admin/ && electron-builder --win",
        "build:linux": "npm run build && electron-builder --linux",
        "e2e": "playwright test",
        "e2e:headed": "playwright test --headed",
        "e2e:ui": "playwright test --ui"
    },
    "private": true,
    "packageManager": "npm@11.8.0",
    "dependencies": {
        "@angular/common": "^21.2.13",
        "@angular/compiler": "^21.2.13",
        "@angular/core": "^21.2.13",
        "@angular/forms": "^21.2.13",
        "@angular/platform-browser": "^21.2.13",
        "@angular/router": "^21.2.13",
        "maplibre-gl": "^5.24.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular/build": "^21.2.11",
        "@angular/cli": "^21.2.11",
        "@angular/compiler-cli": "^21.2.13",
        "@iconify-json/ic": "^1.2.4",
        "@iconify/tailwind": "^1.2.0",
        "@playwright/test": "^1.60.0",
        "autoprefixer": "^10.5.0",
        "daisyui": "^4.12.24",
        "electron": "^41.1.1",
        "electron-builder": "^26.8.1",
        "javascript-obfuscator": "^5.4.3",
        "jsdom": "^28.0.0",
        "postcss": "^8.5.14",
        "prettier": "^3.8.3",
        "selenium-webdriver": "^4.44.0",
        "tailwindcss": "^3.4.17",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "~5.9.2",
        "vitest": "^4.1.7"
    },
    "build": {
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/web-admin/browser/**/*",
            "main.js"
        ],
        "productName": "TuColmadoRD",
        "publish": [
            {
                "provider": "github",
                "owner": "synsetsolutions",
                "repo": "TuColmadoRD-Monorepo"
            }
        ],
        "win": {
            "target": "nsis"
        },
        "linux": {
            "target": [
                { "target": "AppImage", "arch": ["x64"] }
            ],
            "artifactName": "TuColmadoRD-${version}-linux.${ext}",
            "category": "Office"
        },
        "appId": "com.tucolmadord.admin",
        "nsis": {
            "oneClick": false,
            "artifactName": "TuColmadoRD-Setup.exe",
            "allowToChangeInstallationDirectory": true
        }
    }
}
