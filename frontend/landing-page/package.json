    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.68.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.6.1",
