{
  "title": "TuColmadoRD — Infrastructure (VPS)",
  "uid": "tucolmadord-infra",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "tags": ["tucolmadord", "infra", "vps"],
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "{{instance}} CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70,   "color": "yellow" },
              { "value": 85,   "color": "red" }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used"
        },
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{device!~\"loop.*\"}[2m])",
          "legendFormat": "read {{device}}"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{device!~\"loop.*\"}[2m])",
          "legendFormat": "write {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 4,
      "title": "Network Traffic",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[2m])",
          "legendFormat": "rx {{device}}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[2m])",
          "legendFormat": "tx {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 5,
      "title": "Disk Space",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100",
          "legendFormat": "/ used %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70,   "color": "yellow" },
              { "value": 85,   "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Container Memory by Service",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 16, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{container_label_com_docker_swarm_service_name=~\"tucolmadord.*(catalog|reports|traefik|prometheus|grafana)\"}",
          "legendFormat": "{{container_label_com_docker_swarm_service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 1 } }
      }
    },
    {
      "id": 7,
      "title": "Container CPU by Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{container_label_com_docker_swarm_service_name=~\"tucolmadord.*(catalog|reports|traefik|prometheus|grafana)\"}[2m]) * 100",
          "legendFormat": "{{container_label_com_docker_swarm_service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "lineWidth": 1 } }
      }
    }
  ]
}
