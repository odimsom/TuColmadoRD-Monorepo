# Copy to /opt/tucolmadord/.env on the VPS (never commit this file with real values)

# ── App database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tucolmado:CHANGE_ME@postgres:5432/tucolmadord
POSTGRES_USER=tucolmado
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=tucolmadord

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Domains ───────────────────────────────────────────────────────────────────
DOMAIN=tucolmadord.com
ACME_EMAIL=admin@tucolmadord.com

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME
# Basic-auth for Prometheus/Alertmanager routes (htpasswd format: user:bcrypt)
# Generate: htpasswd -nbBC 10 admin yourpassword
TRAEFIK_BASIC_AUTH=admin:$$2y$$10$$...

# ── Alertmanager webhook (e.g. Slack, Discord, custom) ────────────────────────
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Container registry ────────────────────────────────────────────────────────
REGISTRY=ghcr.io/synsetsolutions
TAG=latest
